{
  "name": "@rrkit/tracker",
  "description": "rrkit session-replay browser tracker (rrweb-based).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "rrweb": "^2.0.0-alpha.18"
  },
  "devDependencies": {
    "@rrkit/shared": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
