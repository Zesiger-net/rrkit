# rrkit environment variables
#
# rrkit is zero-config: every variable below has a sensible default, so you can
# run the container without setting any of them. Override only what you need by
# adding them to the `environment:` block of your docker-compose.yml.
#
# NOTE: There is no secret to configure. rrkit generates its JWT signing key on
# first boot and stores it in the SQLite database, so dashboard logins survive
# restarts with no setup. Admin password and S3 credentials are set in the
# dashboard wizard, not here.

# Port the server listens on.
RRKIT_PORT=3000

# Bind address.
RRKIT_HOST=0.0.0.0

# Path to the SQLite database. This is the only file rrkit stores on the host.
# In the official image this lives on the mounted /data volume.
RRKIT_DB_PATH=/data/rrkit.db

# Log verbosity: fatal | error | warn | info | debug | trace
RRKIT_LOG_LEVEL=info

# Advanced / rarely needed. Override the bundled asset locations.
# The dashboard static export and tracker bundle ship inside the image, so you
# normally leave these unset.
# RRKIT_STATIC_DIR=/app/dashboard/out
# RRKIT_TRACKER_PATH=/app/dashboard/out/tracker.js
